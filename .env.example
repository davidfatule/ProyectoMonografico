# Copia este archivo a .env y rellena los valores de tu SQL Server.
# No subas .env al repositorio.

# SQL Server
DB_SERVER=localhost
DB_DATABASE=SoportePro
DB_USER=sa
DB_PASSWORD=tu_contraseña
DB_PORT=1433
DB_ENCRYPT=false

# Puerto del servidor API (el frontend en desarrollo usará proxy a este puerto)
PORT=3001
